    "tree-sitter-python": "^0.25.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-go": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
